[Unit]
Description=Browser-camera ML Flask app (Gunicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/ml
Environment="HOST=127.0.0.1"
Environment="PORT=5000"
Environment="ACCURACY_MODE=1"
Environment="SMOOTH_WINDOW=4"
Environment="DET_CONF=0.45"
Environment="DET_IOU=0.45"
Environment="IMG_SIZE=960"
ExecStart=/home/ubuntu/ml/.venv/bin/gunicorn -c /home/ubuntu/ml/gunicorn.conf.py app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

